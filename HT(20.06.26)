import nltk
from nltk import word_tokenize, pos_tag, ne_chunk
from nltk.parse import ChartParser
from nltk import CFG
from nltk.classify import NaiveBayesClassifier, accuracy
from nltk.metrics import precision
from nltk.probability import FreqDist
from nltk.util import bigrams, trigrams
from nltk.sem import Expression

# Download required datasets
nltk.download('punkt')
nltk.download('punkt_tab')
nltk.download('averaged_perceptron_tagger')
nltk.download('averaged_perceptron_tagger_eng')
nltk.download('maxent_ne_chunker')
nltk.download('maxent_ne_chunker_tab')
nltk.download('words')

# News Article
news = """
Microsoft announced a new AI platform in Chennai.
The company expects the technology to improve business productivity.
"""

# --------------------------------------------------
# 1. Parsing using nltk.parse
# --------------------------------------------------
print("Parsing:")

grammar = CFG.fromstring("""
S -> NP VP
NP -> 'Microsoft'
VP -> V NP2
V -> 'announced'
NP2 -> 'AI_platform'
""")

parser = ChartParser(grammar)

sentence = ["Microsoft", "announced", "AI_platform"]

for tree in parser.parse(sentence):
    print(tree)

print("Subject: Microsoft")
print("Verb: announced")
print("Object: AI platform")

# --------------------------------------------------
# 2. Named Entity Recognition using nltk.chunk
# --------------------------------------------------
print("\nNamed Entities:")

tokens = word_tokenize(news)
tagged = pos_tag(tokens)
entities = ne_chunk(tagged)

for chunk in entities:
    if hasattr(chunk, 'label'):
        entity = " ".join(c[0] for c in chunk)
        if chunk.label() == "ORGANIZATION":
            print("Organization:", entity)
        elif chunk.label() == "GPE":
            print("Location:", entity)
        else:
            print(chunk.label() + ":", entity)

# --------------------------------------------------
# 3. Classification using nltk.classify
# --------------------------------------------------
train_data = [
    ({"AI": True, "technology": True}, "Technology"),
    ({"government": True, "election": True}, "Politics"),
    ({"business": True, "market": True}, "Business"),
    ({"player": True, "match": True}, "Sports")
]

classifier = NaiveBayesClassifier.train(train_data)

features = {
    "AI": "AI" in news,
    "technology": "technology" in news,
    "business": "business" in news
}

category = classifier.classify(features)

print("\nCategory:")
print(category)

# --------------------------------------------------
# 4. Accuracy and Precision using nltk.metrics
# --------------------------------------------------
test_data = train_data

gold = []
predicted = []

for feat, label in test_data:
    gold.append(label)
    predicted.append(classifier.classify(feat))

acc = accuracy(classifier, test_data)

refset = set(i for i, label in enumerate(gold)
             if label == "Technology")

testset = set(i for i, label in enumerate(predicted)
              if label == "Technology")

prec = precision(refset, testset)

print("\nModel Accuracy:")
print(round(acc * 100, 2), "%")

print("Precision:")
print(round(prec * 100, 2), "%")

# --------------------------------------------------
# 5. Word Frequency and Probability Distribution
# --------------------------------------------------
words = [w.lower() for w in word_tokenize(news) if w.isalpha()]

fdist = FreqDist(words)

print("\nWord Frequency:")
for word, freq in fdist.items():
    print(word, ":", freq)

total_words = len(words)

print("\nProbability:")
for word, freq in fdist.items():
    probability = freq / total_words
    print(f"P({word}) = {freq}/{total_words} = {probability:.2f}")

# --------------------------------------------------
# 6. Semantic Analysis using nltk.sem
# --------------------------------------------------
print("\nSemantic Analysis:")

read_expr = Expression.fromstring

expr1 = read_expr('technology(x)')
expr2 = read_expr('business(x)')
expr3 = read_expr('platform(x)')

print(expr1)
print(expr2)
print(expr3)

# --------------------------------------------------
# 7. Bigrams and Trigrams using nltk.util
# --------------------------------------------------
tokens = [w.lower() for w in word_tokenize(news) if w.isalpha()]

print("\nBigrams:")
for bg in bigrams(tokens):
    print(bg)

print("\nTrigrams:")
for tg in trigrams(tokens):
    print(tg)
